# Backend Environment Configuration
# Copy this file to .env and update the values for your environment

# Server Configuration
PORT=8080
LOG_LEVEL=info

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=vibexp_app
# Matches the local Postgres started by `make backend-run-dev` (backend-api/docker-compose.yml).
# Change this for any real deployment.
DB_PASSWORD=local_password
DB_NAME=vibexp_io

# API Authentication
API_KEY_COMMON=your_secure_api_key_here

# Security Configuration
# REQUIRED. Must be EXACTLY 32 bytes (AES-256). The service fails to start otherwise.
# Generate one with: openssl rand -hex 16   (32 hex chars = 32 bytes)
ENCRYPTION_KEY=change_me_to_a_32_byte_secret_ok

# Backoffice API Configuration
# Admin API key for back-office endpoints (/bo/*)
# This is separate from JWT and regular API keys - used ONLY for administrative endpoints
BACKOFFICE_ADMIN_API_KEY=your_backoffice_admin_api_key_here

# HubSpot CRM Configuration
# HubSpot Private App Access Token for automatic contact synchronization
# Leave empty to disable HubSpot CRM integration
HUBSPOT_CRM_ACCESS_KEY=

# Frontend Configuration
FRONTEND_BASE_URL=http://localhost:5173

# CORS allowed origins (comma-separated). When empty, only localhost dev origins
# (http://localhost:5173, http://localhost:5174) are allowed. Set this to your
# production frontend origin(s), e.g.
#   CORS_ALLOWED_ORIGINS=https://app.example.com,https://example.com
CORS_ALLOWED_ORIGINS=

# Resource attachments (GCS) bucket. Leave empty to disable file attachments
# (upload/download/delete return 503). Set to your GCS bucket name to enable.
GCS_RESOURCE_ATTACHMENTS_BUCKET=

# RFC 9457 error "type" base URI. Defaults to the neutral "about:blank". Set it
# to a public URL documenting your error codes (joined as <base>/<code>), e.g.
#   ERROR_TYPE_BASE_URI=https://example.com/errors
ERROR_TYPE_BASE_URI=about:blank

# Embedding pipeline (native, broker-free)
# -----------------------------------------
# Embeddings are generated in-process by an async worker on the event bus: when an
# entity is created/updated, the worker chunks its text in Go, embeds the chunks via
# the active embedding provider, and stores them. There is NO external ai-service and
# NO Pub/Sub — semantic search needs only Postgres (pgvector) + an embedding provider.
#
# The embedding provider (an OpenAI-compatible /v1/embeddings endpoint: OpenAI,
# Ollama, LocalAI, vLLM, TEI, …) is configured in the app (embedding_providers
# table: base_url, api_key, provider_type), NOT via env. If no provider is
# configured, entities are still saved and embedding is simply skipped.
#
# EMBEDDING_MODEL / EMBEDDING_DIMENSIONS are deployment-wide: the model is the
# model_id tag written on every row and the search filter, and the dimension is the
# vector(N) column width. Both must agree with the active migration. Changing the
# dimension is a migration + re-embed operation.
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768

# In-Go document chunker (rune-based sliding window). Overlap preserves context
# across chunk boundaries and must be smaller than the chunk size.
EMBEDDING_CHUNK_SIZE=1000
EMBEDDING_CHUNK_OVERLAP=200

# OIDC auth for internal job endpoints (/internal/jobs/*), e.g. Cloud Scheduler.
# These are unrelated to embeddings; leave empty for local dev.
#   PUBSUB_PUSH_AUDIENCE: public HTTPS URL the OIDC caller targets; the incoming
#     token's audience must match it (e.g. https://api.example.com).
#   PUBSUB_PUSH_SERVICE_ACCOUNT_SUFFIX: optional. Restrict accepted tokens to a
#     service-account domain, e.g. @your-gcp-project-id.iam.gserviceaccount.com.
# GCP_PROJECT_ID is used only for observability (trace/log correlation).
GCP_PROJECT_ID=
PUBSUB_PUSH_AUDIENCE=
PUBSUB_PUSH_SERVICE_ACCOUNT_SUFFIX=

# Development Notes:
# - For local development with Docker Compose, use DB_HOST=postgres and DB_PASSWORD=local_password
# - For external PostgreSQL, update DB_HOST to your database server address
# - Generate a secure API key for authentication testing
# - Generate a 32-character encryption key for sensitive data encryption
# - FRONTEND_BASE_URL should be http://localhost:5173 for local dev, your production app URL otherwise

# GitHub App Configuration (Required for GitHub integration)
# Enable users to install your GitHub App in their organizations/repositories
#
# Obtain these credentials from your GitHub App settings:
# https://github.com/settings/apps/your-app-name
#
# GITHUB_APP_ID: App ID found at the top of your GitHub App settings page
# GITHUB_APP_PRIVATE_KEY: Base64-encoded private key (see docs for encoding instructions)
#   Generate: cat private-key.pem | base64 -w 0
# GITHUB_CLIENT_ID: OAuth Client ID for user authorization flow
# GITHUB_CLIENT_SECRET: OAuth Client Secret for user authorization flow
# GITHUB_WEBHOOK_URL: Public URL where GitHub sends webhook events
#   Example: https://api.example.com/webhooks/github
# GITHUB_WEBHOOK_SECRET: Secret for verifying webhook payloads from GitHub
#
# Security Note: Never commit actual secrets to version control.
# The private key should be base64-encoded for environment variable storage.
#
# GitHub integration is OPTIONAL — leave EMPTY for local dev (the provider stubs
# out). Set these to enable the GitHub App / OAuth integration in production.
# (A non-empty but invalid GITHUB_APP_PRIVATE_KEY fails startup on PEM parsing.)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_URL=https://api.example.com/webhooks/github
GITHUB_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Authentication provider selection
# ---------------------------------------------------------------------------
# AUTH_PROVIDER selects the web-login identity provider. Valid values:
#   workos  - WorkOS AuthKit (set WORKOS_* below)
#   oidc    - any generic OIDC provider: Keycloak, Authentik, Zitadel, Auth0,
#             Google (set OIDC_* below)
#   (empty) - none / auto-detect: uses WorkOS if WORKOS_CLIENT_ID + WORKOS_API_KEY
#             are present, otherwise a no-op stub (web login disabled; dev login
#             still works). This is the default and keeps local dev unchanged.
#
# Misconfiguration is never fatal: if the selected provider can't initialize
# (e.g. OIDC discovery fails against a bad/unreachable issuer), the backend logs
# a WARNING, falls back to the no-op stub, and still boots — web login is
# disabled but dev login (DEV_LOGIN_ENABLED=true) keeps working.
AUTH_PROVIDER=

# Generic OIDC provider settings (used when AUTH_PROVIDER=oidc).
# Works with any OIDC-compliant issuer. OIDC_ISSUER_URL is the issuer used for
# discovery (the backend appends /.well-known/openid-configuration).
#
#   OIDC_ISSUER_URL:    e.g. https://keycloak.example.com/realms/vibexp
#   OIDC_CLIENT_ID:     OAuth client ID registered with the provider
#   OIDC_CLIENT_SECRET: OAuth client secret for that client
#   OIDC_REDIRECT_URI:  callback URI registered with the provider
#                       Local: http://localhost:8080/api/v1/auth/callback
#                       Prod:  https://api.example.com/api/v1/auth/callback
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:8080/api/v1/auth/callback

# WorkOS Configuration (used when AUTH_PROVIDER=workos, or auto-detected when
# AUTH_PROVIDER is empty and both credentials below are set).
# Obtain these credentials from your WorkOS dashboard: https://dashboard.workos.com/
#
# WORKOS_API_KEY: WorkOS API key
# WORKOS_CLIENT_ID: WorkOS Client ID
# WORKOS_COOKIE_PASSWORD: 32-byte hex string used to derive the AES-GCM key
#                         that encrypts the vx_session cookie payload
# WORKOS_REDIRECT_URI: OAuth callback URI registered in the WorkOS dashboard
#                      Local: http://localhost:8080/api/v1/auth/callback
#                      Prod:  https://api.example.com/api/v1/auth/callback
# DEV_LOGIN_ENABLED: Set to "true" ONLY in local development to enable
#                    /api/v1/auth/dev/login (bypasses WorkOS). Defaults to
#                    false. Has no effect outside development environments.
# SIGNIN_ALLOWED_EMAILS: Comma-separated allowlist of email addresses permitted
#                        to sign in. Empty (the default) means open registration
#                        — anyone can sign in. Set a list to restrict sign-in,
#                        e.g. SIGNIN_ALLOWED_EMAILS=alice@example.com,bob@example.com
#
# Security Note: Never commit actual secrets to version control.
#
# Leave WORKOS_API_KEY and WORKOS_CLIENT_ID EMPTY for local development: the
# backend then uses a no-op auth provider and you sign in via dev login
# (DEV_LOGIN_ENABLED=true below). Set BOTH to your WorkOS AuthKit credentials
# to enable production web login. (If you set a non-empty but invalid client
# ID, startup fails on OIDC discovery — so keep them empty unless real.)
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
# 64 hex chars = 32 bytes. Throwaway local-dev value so dev login works out of the box;
# generate your own for production: openssl rand -hex 32
WORKOS_COOKIE_PASSWORD=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
WORKOS_REDIRECT_URI=http://localhost:8080/api/v1/auth/callback
DEV_LOGIN_ENABLED=true
SIGNIN_ALLOWED_EMAILS=

# ---------------------------------------------------------------------------
# MCP OAuth 2.1 Resource Server (MCP authorization spec 2025-06-18)
# ---------------------------------------------------------------------------
# The /mcp/v1/common endpoint is an OAuth 2.1 resource server that delegates
# authorization to WorkOS AuthKit. It accepts only AuthKit-issued bearer JWTs
# minted for MCP_RESOURCE_URI (RFC 8707 audience binding).
#
# MCP_OAUTH_ISSUER: AuthKit issuer URL. Differs per environment, so it must be
#                   provided via env var and never hardcoded. JWKS is fetched
#                   from <issuer>/oauth2/jwks. Leave empty to disable the MCP
#                   endpoint (it will reject all tokens with 401).
#                   Example: https://your-tenant.authkit.app
# MCP_RESOURCE_URI: Canonical MCP resource identifier and required token
#                   audience. Required to enable the MCP endpoint; no default.
#                   Example: https://connect.example.com/mcp/v1/common
MCP_OAUTH_ISSUER=
MCP_RESOURCE_URI=

# ---------------------------------------------------------------------------
# API-surface OAuth (AuthKit bearer JWTs on /api/v1/*)
# ---------------------------------------------------------------------------
# When API_OAUTH_ISSUER is set, /api/v1/* accepts AuthKit-issued bearer JWTs
# (mobile and other native OAuth+PKCE clients) alongside session cookies and
# API keys. Leave empty to disable (non-API-key bearer tokens get 401).
#
# API_OAUTH_ISSUER:    AuthKit issuer URL, same per-environment values as
#                      MCP_OAUTH_ISSUER above. JWKS is fetched from
#                      <issuer>/oauth2/jwks.
# API_OAUTH_AUDIENCES: Optional comma-separated aud-claim allow-list. Plain
#                      AuthKit PKCE access tokens carry no aud claim, so the
#                      default accepts any audience EXCEPT the MCP resource URI
#                      (MCP-bound tokens stay MCP-only); issuer, signature,
#                      expiry, and subject-to-user binding are always enforced.
#                      Set this only if tokens are minted with RFC 8707
#                      resource indicators for the API. Note: with the default,
#                      ANY AuthKit access token from the issuer for a
#                      provisioned user is an API credential — including the
#                      access token inside web sessions; never log or forward
#                      such tokens.
API_OAUTH_ISSUER=
API_OAUTH_AUDIENCES=

# Event Bus Retry Configuration (Optional - production-optimized defaults)
# Configure retry behavior for transient failures in event processing (GA4 tracking, HubSpot sync, etc.)
#
# Defaults are optimized for production reliability and performance.
# For local development, you may want to reduce these values:
#   EVENT_BUS_WORKER_COUNT=10
#   EVENT_BUS_BUFFER_SIZE=100
#   EVENT_BUS_RETRY_BACKOFF=100ms
#   EVENT_BUS_RETRY_JITTER=false
#
# EVENT_BUS_WORKER_COUNT: Concurrent workers processing events (default: 20, max: 1000)
#   Higher values = better throughput, more CPU/memory usage
#   Values above 1000 are capped to prevent resource exhaustion
#
# EVENT_BUS_BUFFER_SIZE: Event queue buffer size (default: 500, max: 10000)
#   Higher values = handles traffic bursts, uses more memory
#   Values above 10000 are capped to prevent excessive memory usage
#
# EVENT_BUS_MAX_RETRIES: Maximum retry attempts per event (default: 3, max: 10)
#   Formula: 3 retries with 200ms backoff = max 1.4s delay (200ms + 400ms + 800ms)
#   Values above 10 are capped to prevent excessive delays
#
# EVENT_BUS_RETRY_BACKOFF: Base retry delay (default: 200ms, max: 5s, exponential backoff)
#   Formula: delay = backoff * 2^attempt (e.g., 200ms -> 400ms -> 800ms)
#   Final backoff is capped at 30s per attempt regardless of base value
#   Values above 5s are capped to prevent excessive initial backoff
#
# EVENT_BUS_RETRY_JITTER: Randomize backoff to prevent thundering herd (default: true)
#   Adds ±10% randomness - critical for multi-instance deployments
#
# Security Note: All configuration values are validated and capped at sensible maximums
# to prevent resource exhaustion attacks or misconfiguration.
#
# Leave commented to use production-optimized defaults
# Uncomment and adjust for development or custom tuning
#EVENT_BUS_WORKER_COUNT=20
#EVENT_BUS_BUFFER_SIZE=500
#EVENT_BUS_MAX_RETRIES=3
#EVENT_BUS_RETRY_BACKOFF=200ms
#EVENT_BUS_RETRY_JITTER=true

# Email Delivery Configuration
#
# EMAIL_PROVIDER selects the delivery backend. Valid values: smtp (default), mailgun.
# EMAIL_FROM_ADDRESS sets the sender address for all providers.
#   - When empty, falls back to SMTP_USERNAME for backwards compatibility (smtp provider only).
#   - Required when using mailgun (smtp provider can infer from SMTP_USERNAME).
#
# CONTACT_RECIPIENT_ADDRESS is the inbox that receives contact-form and support
# notification emails. When empty it falls back to EMAIL_FROM_ADDRESS, then
# SMTP_USERNAME.
#
# Example:
#   EMAIL_PROVIDER=mailgun
#   EMAIL_FROM_ADDRESS=noreply@example.com
#   CONTACT_RECIPIENT_ADDRESS=hello@example.com
EMAIL_PROVIDER=smtp
EMAIL_FROM_ADDRESS=
CONTACT_RECIPIENT_ADDRESS=

# SMTP provider settings (required when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=xxxxx
SMTP_PASSWORD=xxxx

# Mailgun provider settings (required when EMAIL_PROVIDER=mailgun)
# Obtain these credentials from your Mailgun dashboard: https://app.mailgun.com/
#
# MAILGUN_DOMAIN: Your Mailgun sending domain (e.g. mg.example.com).
#   Found in Mailgun Dashboard → Sending → Domains
# MAILGUN_SENDING_KEY: Your Mailgun Private API key.
#   Found in Mailgun Dashboard → Sending → Domain Settings → API Keys
# MAILGUN_BASE_URL: Optional. API base URL for region selection.
#   Use https://api.mailgun.net/v3 (US, default) or https://api.eu.mailgun.net/v3 (EU).
#   Leave empty to use the US default.
MAILGUN_DOMAIN=mg.example.com
MAILGUN_SENDING_KEY=your_mailgun_api_key_here
MAILGUN_BASE_URL=

# OpenTelemetry Configuration (Optional - for metrics and tracing)
# Configure OpenTelemetry metrics export for observability
#
# OTEL_EXPORTER_OTLP_ENDPOINT: OTLP collector endpoint (gRPC format: host:port without scheme)
# OTEL_METRIC_EXPORT_INTERVAL: How often to export metrics (e.g., "60s", "5m")
# SERVICE_VERSION: Service version for metrics tagging (useful for tracking deployments)
#
# Leave empty to use defaults (localhost:4317, 60s export interval)
# For production, configure to point to your observability backend
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_METRIC_EXPORT_INTERVAL=60s
SERVICE_VERSION=dev

# A2A (Agent-to-Agent) Configuration (Optional)
# Configure timeout for agent-to-agent HTTP communication
#
# A2A_DEFAULT_TIMEOUT: Maximum time to wait for agent responses (e.g., "5m", "300s")
# Default: 5m (5 minutes)
# Increase for long-running agent tasks, decrease for faster failure detection
A2A_DEFAULT_TIMEOUT=5m

# Deployment Environment Configuration (Optional - mostly auto-detected)
# These variables help identify the deployment environment for metrics and logging
# Most are auto-detected from cloud platforms - manual setting is rarely needed
#
# OTEL_ENVIRONMENT: OpenTelemetry standard environment variable (takes precedence)
# ENVIRONMENT, ENV, DEPLOYMENT_ENVIRONMENT: Alternative environment indicators
#
# Auto-detected indicators (read-only, set by platform):
# - KUBERNETES_SERVICE_HOST: Auto-set by Kubernetes
# - GOOGLE_CLOUD_PROJECT, GCP_PROJECT: Auto-set by Google Cloud
# - AWS_REGION, AWS_DEFAULT_REGION: Auto-set by AWS
#
# Common values: development, staging, production
# If none set, defaults to "production"
#
# Example for local development:
# OTEL_ENVIRONMENT=development
OTEL_ENVIRONMENT=

# Abuse hardening (Optional - all have safe defaults)
# MAX_BODY_SIZE_BYTES: Global request-body cap in bytes (default 10MiB / 10485760).
#   Memory-exhaustion backstop only; set generously above legitimate payloads
#   (artifact/memory content is unbounded). Contact form & webhooks cap at 64KiB.
# AUTH_RATE_LIMIT_PER_MINUTE: Per-IP limit on /api/v1/auth/* (default 10).
# CONTACT_RATE_LIMIT_PER_MINUTE: Per-IP limit on the contact form (default 5).
# API_RATE_LIMIT_PER_MINUTE: Per-IP limit on the authenticated API surface (default 100).
MAX_BODY_SIZE_BYTES=10485760
AUTH_RATE_LIMIT_PER_MINUTE=10
CONTACT_RATE_LIMIT_PER_MINUTE=5
API_RATE_LIMIT_PER_MINUTE=100
