# Backend secrets — copy this file to .env and fill in real values.
# ===========================================================================
# This file holds ONLY secrets. All non-secret configuration (ports, hosts,
# providers, timeouts, …) lives in config.yaml — see config.example.yaml, the
# primary documented config surface. config.yaml references each secret below as
# ${VAR}; `make backend-run`/`backend-run-dev` load this .env into the process
# environment so those references resolve.
#
# The values below are throwaway LOCAL-DEVELOPMENT defaults so a fresh clone
# boots out of the box. Generate real secrets for any real deployment, and never
# commit a populated .env (it is gitignored).

# REQUIRED. Database password. Matches the dev Postgres in
# backend/docker-compose.yml; change it for any real deployment.
DB_PASSWORD=local_password

# REQUIRED. Must be EXACTLY 32 bytes (AES-256); the service fails to start
# otherwise. Generate one with: openssl rand -hex 16
ENCRYPTION_KEY=change_me_to_a_32_byte_secret_ok

# Optional. Global API key for the common API surface, and the back-office
# super-admin key (/bo/*). Leave empty for local dev.
API_KEY_COMMON=
BACKOFFICE_ADMIN_API_KEY=

# Session cookie key: 64 hex chars (32 bytes). Empty disables cookie session
# auth. This throwaway dev value lets dev login work out of the box; generate
# your own for production: openssl rand -hex 32
SESSION_ENCRYPTION_KEY=deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef

# Web-login provider secrets. Set the one(s) you enable in auth.providers
# (config.yaml); the matching client_id and redirect_uri live there too. Leave
# empty for local dev (sign in via dev login instead).
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_SECRET=
OIDC_CLIENT_SECRET=

# GitHub App integration secrets (optional; leave empty for local dev). The
# private key is base64-encoded: cat private-key.pem | base64 -w 0
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
# OAuth secret of the same GitHub App, used to verify the installing user can
# administer the installation before it is bound to a team.
GITHUB_APP_CLIENT_SECRET=

# Email provider secrets. SMTP_PASSWORD is a throwaway value Mailpit (the local
# SMTP sink) accepts as-is. Set the secret for whichever provider you select in
# email.provider (config.yaml); leave the rest empty.
SMTP_PASSWORD=dev
MAILGUN_SENDING_KEY=
POSTMARK_SERVER_TOKEN=
SENDGRID_API_KEY=
