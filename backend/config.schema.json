        "content_version_limit": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "SMTPConfig": {
      "properties": {
        "host": {
          "type": "string"
        },
        "port": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "password": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
