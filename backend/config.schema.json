        "rank_weight_created": {
          "type": "number"
        },
        "rank_weight_updated": {
          "type": "number"
        },
        "rank_half_life_days": {
          "type": "number"
        },
        "rank_candidate_cap": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "SecurityConfig": {
      "properties": {
        "encryption_key": {
          "type": "string"
        },
        "api_key_common": {
          "type": "string"
        },
        "backoffice_admin_api_key": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
