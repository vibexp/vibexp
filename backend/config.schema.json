          "$ref": "#/$defs/MailgunConfig"
        },
        "postmark": {
          "$ref": "#/$defs/PostmarkConfig"
        },
        "sendgrid": {
          "$ref": "#/$defs/SendGridConfig"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
