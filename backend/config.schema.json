        "domain": {
          "type": "string"
        },
        "sending_key": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "OAuthASConfig": {
      "properties": {
        "issuer_url": {
          "type": "string"
        },
        "access_token_ttl": {
          "type": "string",
          "pattern": "^-?(\\d+(\\.\\d+)?(ns|us|µs|ms|s|m|h))+$"
        },
        "refresh_token_ttl": {
          "type": "string",
          "pattern": "^-?(\\d+(\\.\\d+)?(ns|us|µs|ms|s|m|h))+$"
        },
        "auth_code_ttl": {
          "type": "string",
          "pattern": "^-?(\\d+(\\.\\d+)?(ns|us|µs|ms|s|m|h))+$"
        },
        "key_rotation_interval": {
          "type": "string",
          "pattern": "^-?(\\d+(\\.\\d+)?(ns|us|µs|ms|s|m|h))+$"
        },
        "cleanup_interval": {
          "type": "string",
          "pattern": "^-?(\\d+(\\.\\d+)?(ns|us|µs|ms|s|m|h))+$"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
