        "chunk_overlap": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "EventsConfig": {
      "properties": {
        "worker_count": {
          "type": "integer"
        },
        "buffer_size": {
          "type": "integer"
        },
        "max_retries": {
          "type": "integer"
        },
        "retry_backoff": {
          "type": "string",
          "pattern": "^-?(\\d+(\\.\\d+)?(ns|us|µs|ms|s|m|h))+$"
        },
        "retry_jitter": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "FCMConfig": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "FrontendConfig": {
      "properties": {
        "base_url": {
          "type": "string"
        },
        "site_name": {
          "type": "string"
        },
        "site_legal_name": {
          "type": "string"
        },
        "site_url": {
          "type": "string"
        },
        "terms_url": {
          "type": "string"
        },
        "privacy_url": {
          "type": "string"
        },
        "support_email": {
          "type": "string"
        },
        "brand_logo_url": {
          "type": "string"
