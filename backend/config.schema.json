    "SendGridConfig": {
      "properties": {
        "api_key": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ServerConfig": {
      "properties": {
        "port": {
          "type": "string"
        },
        "log_level": {
          "type": "string"
