{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/vibexp/vibexp/internal/config/config",
  "$ref": "#/$defs/Config",
  "$defs": {
    "A2AConfig": {
      "properties": {
        "default_timeout": {
          "type": "string",
          "pattern": "^-?(\\d+(\\.\\d+)?(ns|us|µs|ms|s|m|h))+$"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "APIOAuthConfig": {
      "properties": {
        "issuer": {
          "type": "string"
        },
        "audiences": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "AuthConfig": {
      "properties": {
        "providers": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "provider": {
          "type": "string"
        },
        "session_encryption_key": {
          "type": "string"
        },
        "dev_login_enabled": {
          "type": "boolean"
        },
        "signin_allowed_emails": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "google": {
          "$ref": "#/$defs/GoogleAuthConfig"
        },
        "github": {
          "$ref": "#/$defs/GitHubAuthConfig"
        },
        "oidc": {
          "$ref": "#/$defs/OIDCAuthConfig"
        },
        "oauth_as": {
          "$ref": "#/$defs/OAuthASConfig"
        },
        "api_oauth": {
          "$ref": "#/$defs/APIOAuthConfig"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Config": {
      "properties": {
        "server": {
          "$ref": "#/$defs/ServerConfig"
        },
        "database": {
          "$ref": "#/$defs/DatabaseConfig"
        },
        "security": {
          "$ref": "#/$defs/SecurityConfig"
        },
        "auth": {
          "$ref": "#/$defs/AuthConfig"
        },
        "mcp": {
          "$ref": "#/$defs/MCPConfig"
        },
        "email": {
          "$ref": "#/$defs/EmailConfig"
        },
        "frontend": {
          "$ref": "#/$defs/FrontendConfig"
        },
        "search": {
          "$ref": "#/$defs/SearchConfig"
        },
        "embedding": {
          "$ref": "#/$defs/EmbeddingConfig"
        },
        "github": {
          "$ref": "#/$defs/GitHubConfig"
        },
        "storage": {
          "$ref": "#/$defs/StorageConfig"
        },
        "gcp": {
          "$ref": "#/$defs/GCPConfig"
        },
        "rate_limit": {
          "$ref": "#/$defs/RateLimitConfig"
        },
        "retention": {
          "$ref": "#/$defs/RetentionConfig"
        },
        "a2a": {
          "$ref": "#/$defs/A2AConfig"
        },
        "fcm": {
          "$ref": "#/$defs/FCMConfig"
        },
        "deployment": {
          "$ref": "#/$defs/DeploymentConfig"
        },
        "event_bus": {
          "$ref": "#/$defs/EventsConfig"
        },
        "otel": {
          "$ref": "#/$defs/ObservabilityConfig"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "DatabaseConfig": {
      "properties": {
        "host": {
          "type": "string"
        },
        "port": {
          "type": "string"
        },
        "user": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "name": {
          "type": "string"
