        "client_secret": {
          "type": "string"
        },
        "redirect_uri": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ObservabilityConfig": {
      "properties": {
        "endpoint": {
          "type": "string"
        },
        "export_interval": {
          "type": "string",
          "pattern": "^-?(\\d+(\\.\\d+)?(ns|us|µs|ms|s|m|h))+$"
        },
        "trace_sample_ratio": {
          "type": "number"
        },
        "tracing_enabled": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "PostmarkConfig": {
      "properties": {
        "server_token": {
          "type": "string"
