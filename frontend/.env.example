# ---------------------------------------------------------------------------
# Backend API
# ---------------------------------------------------------------------------
# Base URL of the backend API, including the version prefix.
# Leave empty to issue same-origin relative requests (recommended when the
# frontend and API are served from the same host / behind one proxy).
# Example: https://your-api-host.example.com/api/v1
# Local-dev default targets `make backend-run-dev` (backend on :8080):
VITE_API_BASE_URL=http://localhost:8080/api/v1

# ---------------------------------------------------------------------------
# Branding / site links (shown in the UI; all optional with neutral defaults)
# ---------------------------------------------------------------------------
# Product/brand display name.
VITE_SITE_NAME=

# Legal entity name shown in copyright notices (defaults to VITE_SITE_NAME).
VITE_SITE_LEGAL_NAME=

# Public marketing/home site URL (brand links). Example: https://example.com
VITE_SITE_URL=

# Terms & Conditions / Privacy Policy page URLs.
# Default to <VITE_SITE_URL>/terms-and-conditions and /privacy-policy.
VITE_TERMS_URL=
VITE_PRIVACY_URL=

# Support contact email address.
VITE_SUPPORT_EMAIL=

# Absolute URL to the brand logo (OpenGraph image on shared pages).
VITE_BRAND_LOGO_URL=

# ---------------------------------------------------------------------------
# MCP
# ---------------------------------------------------------------------------
# The MCP endpoint advertised in the client-setup snippets.
# Example: https://connect.example.com/mcp/v1/common
VITE_MCP_ENDPOINT=

# ---------------------------------------------------------------------------
# Error reporting / problem details
# ---------------------------------------------------------------------------
# Base URI used to build RFC 9457 problem-detail `type` fields client-side as a
# fallback (e.g. <base>/errors/UNKNOWN). Leave empty to use "about:blank".
VITE_ERROR_TYPE_BASE_URI=

# ---------------------------------------------------------------------------
# Analytics (Google Tag Manager / GA4) — disabled by default
# ---------------------------------------------------------------------------
# Google Tag Manager container ID (e.g. GTM-XXXXXXX). Empty disables GTM.
VITE_GTM_ID=

# GA4 Measurement ID for client ID capture (e.g. G-XXXXXXXXXX).
VITE_GA4_MEASUREMENT_ID=

# Set to 'true' to enable GTM. Default is false — must be explicitly enabled.
VITE_GTM_ENABLED=false

# ---------------------------------------------------------------------------
# Firebase configuration for FCM Web Push notifications
# Leave all empty to disable browser push notifications
# ---------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
